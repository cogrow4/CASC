{
  "casc_version": "0.1",
  "id": "org.casc.examples.filter",
  "name": "CASC Filter",
  "version": "1.0.0",
  "vendor": "CASC Examples",
  "url": "https://github.com/cogrow4/CASC",
  "description": "Stereo state-variable filter with selectable Lowpass / Highpass / Bandpass response and resonance.",
  "category": "filter",
  "features": ["audio-effect", "stereo"],
  "audio_inputs": [ { "name": "main", "channels": 2 } ],
  "audio_outputs": [ { "name": "main", "channels": 2 } ],
  "midi_input": false,
  "midi_output": false,
  "mpe_support": false,
  "note_ports": [],
  "latency_frames": 0,
  "tail_seconds": 0.0,
  "hard_realtime": true,
  "params": [
    { "id": 0, "name": "Cutoff",    "short_name": "Cut", "module": "Filter", "min": 0.0, "max": 1.0, "default": 0.7, "unit": "Hz", "flags": ["automatable","modulatable"], "steps": null },
    { "id": 1, "name": "Resonance", "short_name": "Res", "module": "Filter", "min": 0.0, "max": 1.0, "default": 0.2, "unit": "",   "flags": ["automatable","modulatable"], "steps": null },
    { "id": 2, "name": "Type",      "short_name": "Type","module": "Filter", "min": 0.0, "max": 1.0, "default": 0.0, "unit": "",   "flags": ["automatable","stepped"], "steps": 3 }
  ],
  "gui": { "type": "html", "entry": "ui.html", "width": 460, "height": 320, "resizable": false }
}
