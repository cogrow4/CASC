{
  "casc_version": "0.1",
  "id": "org.casc.examples.chorus",
  "name": "CASC Chorus",
  "version": "1.0.0",
  "vendor": "CASC Examples",
  "url": "https://github.com/cogrow4/CASC",
  "description": "Stereo chorus: two modulated short delay lines with quadrature LFOs for wide stereo movement.",
  "category": "chorus",
  "features": ["audio-effect", "stereo"],
  "audio_inputs": [ { "name": "main", "channels": 2 } ],
  "audio_outputs": [ { "name": "main", "channels": 2 } ],
  "midi_input": false,
  "midi_output": false,
  "mpe_support": false,
  "note_ports": [],
  "latency_frames": 0,
  "tail_seconds": 0.0,
  "hard_realtime": true,
  "params": [
    { "id": 0, "name": "Rate",  "short_name": "Rate", "module": "Chorus", "min": 0.0, "max": 1.0, "default": 0.3, "unit": "Hz", "flags": ["automatable","modulatable"], "steps": null },
    { "id": 1, "name": "Depth", "short_name": "Dpth", "module": "Chorus", "min": 0.0, "max": 1.0, "default": 0.5, "unit": "%",  "flags": ["automatable","modulatable"], "steps": null },
    { "id": 2, "name": "Mix",   "short_name": "Mix",  "module": "Output", "min": 0.0, "max": 1.0, "default": 0.5, "unit": "%",  "flags": ["automatable","modulatable"], "steps": null }
  ],
  "gui": { "type": "html", "entry": "ui.html", "width": 460, "height": 320, "resizable": false }
}
