{
  "casc_version": "0.1",
  "id": "org.casc.examples.reverb",
  "name": "CASC Reverb",
  "version": "1.0.0",
  "vendor": "CASC Examples",
  "url": "https://github.com/cogrow4/CASC",
  "description": "Lush algorithmic reverb (Freeverb-style): 8 comb + 4 allpass per channel with damping and stereo width.",
  "category": "reverb",
  "features": ["audio-effect", "stereo", "tail"],
  "audio_inputs": [ { "name": "main", "channels": 2 } ],
  "audio_outputs": [ { "name": "main", "channels": 2 } ],
  "midi_input": false,
  "midi_output": false,
  "mpe_support": false,
  "note_ports": [],
  "latency_frames": 0,
  "tail_seconds": 4.0,
  "hard_realtime": true,
  "params": [
    { "id": 0, "name": "Size",    "short_name": "Size", "module": "Reverb", "min": 0.0, "max": 1.0, "default": 0.5,  "unit": "",  "flags": ["automatable","modulatable"], "steps": null },
    { "id": 1, "name": "Damping", "short_name": "Damp", "module": "Reverb", "min": 0.0, "max": 1.0, "default": 0.5,  "unit": "",  "flags": ["automatable","modulatable"], "steps": null },
    { "id": 2, "name": "Width",   "short_name": "Wid",  "module": "Reverb", "min": 0.0, "max": 1.0, "default": 1.0,  "unit": "",  "flags": ["automatable","modulatable"], "steps": null },
    { "id": 3, "name": "Mix",     "short_name": "Mix",  "module": "Output", "min": 0.0, "max": 1.0, "default": 0.33, "unit": "%", "flags": ["automatable","modulatable"], "steps": null }
  ],
  "gui": { "type": "html", "entry": "ui.html", "width": 460, "height": 320, "resizable": false }
}
