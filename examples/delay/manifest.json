{
  "casc_version": "0.1",
  "id": "org.casc.examples.delay",
  "name": "CASC Delay",
  "version": "1.0.0",
  "vendor": "CASC Examples",
  "url": "https://github.com/cogrow4/CASC",
  "description": "Stereo delay with feedback and a one-pole lowpass (Tone) on the feedback path.",
  "category": "delay",
  "features": ["audio-effect", "stereo"],
  "audio_inputs": [ { "name": "main", "channels": 2 } ],
  "audio_outputs": [ { "name": "main", "channels": 2 } ],
  "midi_input": false,
  "midi_output": false,
  "mpe_support": false,
  "note_ports": [],
  "latency_frames": 0,
  "tail_seconds": 2.0,
  "hard_realtime": true,
  "params": [
    { "id": 0, "name": "Time",     "short_name": "Time", "module": "Delay",  "min": 0.0, "max": 1.0, "default": 0.25, "unit": "ms", "flags": ["automatable","modulatable"], "steps": null },
    { "id": 1, "name": "Feedback", "short_name": "FB",   "module": "Delay",  "min": 0.0, "max": 1.0, "default": 0.35, "unit": "%",  "flags": ["automatable","modulatable"], "steps": null },
    { "id": 2, "name": "Tone",     "short_name": "Tone", "module": "Delay",  "min": 0.0, "max": 1.0, "default": 0.7,  "unit": "%",  "flags": ["automatable","modulatable"], "steps": null },
    { "id": 3, "name": "Mix",      "short_name": "Mix",  "module": "Output", "min": 0.0, "max": 1.0, "default": 0.35, "unit": "%",  "flags": ["automatable","modulatable"], "steps": null }
  ],
  "gui": { "type": "html", "entry": "ui.html", "width": 460, "height": 320, "resizable": false }
}
